// ================ STORAGE ================
function loadUsers(){ try{return JSON.parse(localStorage.getItem("majali_users")||"{}")}catch(e){return{}} }
function saveUsers(u){ try{localStorage.setItem("majali_users",JSON.stringify(u))}catch(e){} }
function tasksKey(role){ return "majali_tasks_"+role }
function loadTasks(role){ try{return JSON.parse(localStorage.getItem(tasksKey(role))||"{}")}catch(e){return{}} }
function saveTasks(role,data){ try{localStorage.setItem(tasksKey(role),JSON.stringify(data))}catch(e){} }
function saveSession(s){ try{localStorage.setItem("majali_session",JSON.stringify(s))}catch(e){} }
function loadSession(){ try{return JSON.parse(localStorage.getItem("majali_session")||"null")}catch(e){return null} }
function clearSession(){ try{localStorage.removeItem("majali_session")}catch(e){} }

// ================ AUTH UI ================
function switchTab(tab){
  const isLogin = tab === "login";
  document.getElementById("tabLogin").classList.toggle("active", isLogin);
  document.getElementById("tabSignup").classList.toggle("active", !isLogin);
  document.getElementById("loginForm").style.display = isLogin ? "block" : "none";
  document.getElementById("signupForm").style.display = isLogin ? "none" : "block";
  document.getElementById("authTitle").textContent = isLogin ? "تسجيل الدخول" : "إنشاء حساب جديد";
  document.getElementById("authSubtitle").textContent = isLogin
    ? "أهلاً بعودتك — ادخل بياناتك للمتابعة"
    : "سجّل حسابك لأول مرة واختر دورك في الفريق";
  hideMessages();
}

function showError(msg){
  const e = document.getElementById("authError");
  e.textContent = msg;
  e.classList.add("show");
  document.getElementById("authSuccess").classList.remove("show");
}
function showSuccess(msg){
  const e = document.getElementById("authSuccess");
  e.textContent = msg;
  e.classList.add("show");
  document.getElementById("authError").classList.remove("show");
}
function hideMessages(){
  document.getElementById("authError").classList.remove("show");
  document.getElementById("authSuccess").classList.remove("show");
}

// ================ LOGIN ================
function handleLogin(){
  const username = document.getElementById("loginUsername").value.trim();
  const password = document.getElementById("loginPassword").value;

  if(!username || !password){
    showError("الرجاء إدخال اسم المستخدم وكلمة المرور");
    return;
  }

  // Admin check
  if(username === ADMIN.username && password === ADMIN.password){
    currentSession = { username:"Admin", role:"admin", isAdmin:true };
    saveSession(currentSession);
    enterApp();
    return;
  }

  // Regular user check
  const users = loadUsers();
  const user = users[username];

  if(!user){
    showError("اسم المستخدم غير موجود");
    return;
  }
  if(user.password !== password){
    showError("كلمة المرور غير صحيحة");
    return;
  }

  currentSession = { username, role:user.role, isAdmin:false };
  saveSession(currentSession);
  enterApp();
}

// ================ SIGNUP ================
function handleSignup(){
  const role = document.getElementById("signupRole").value;
  const username = document.getElementById("signupUsername").value.trim();
  const password = document.getElementById("signupPassword").value;

  if(!role){ showError("الرجاء اختيار دورك في الفريق"); return; }
  if(!username){ showError("الرجاء إدخال اسم المستخدم"); return; }
  if(username.toLowerCase() === "admin"){ showError("اسم المستخدم هذا محجوز، اختر اسماً آخر"); return; }
  if(username.length < 3){ showError("اسم المستخدم يجب أن يكون 3 أحرف على الأقل"); return; }
  if(!password || password.length < 6){ showError("كلمة المرور يجب أن تكون 6 أحرف على الأقل"); return; }

  const users = loadUsers();

  // Check if username taken
  if(users[username]){ showError("اسم المستخدم مستخدم بالفعل، اختر غيره"); return; }

  // Check if role taken
  const roleTaken = Object.values(users).find(u => u.role === role);
  if(roleTaken){
    showError("هذا الدور مسجّل بالفعل باسم: " + Object.keys(users).find(k => users[k].role === role));
    return;
  }

  users[username] = { password, role };
  saveUsers(users);

  showSuccess("تم إنشاء الحساب بنجاح! جاري الدخول...");
  setTimeout(() => {
    currentSession = { username, role, isAdmin:false };
    saveSession(currentSession);
    enterApp();
  }, 900);
}

// ================ ENTER/EXIT APP ================
function enterApp(){
  document.getElementById("authScreen").style.display = "none";
  document.getElementById("mainApp").style.display = "block";

  if(currentSession.isAdmin){
    document.getElementById("userView").style.display = "none";
    document.getElementById("adminView").style.display = "block";
    document.getElementById("resetBtn").style.display = "none";
    document.getElementById("headerSubtitle").textContent = "لوحة المدير — مراقبة تقدم الفريق";
    renderAdmin();
  } else {
    document.getElementById("userView").style.display = "block";
    document.getElementById("adminView").style.display = "none";
    document.getElementById("resetBtn").style.display = "inline-block";
    document.getElementById("headerSubtitle").textContent = "السبت → الخميس • إدارة يومية للفريق";
    taskStatuses = loadTasks(currentSession.role);
    renderUser();
  }
  renderBadge();
}

function logout(){
  clearSession();
  currentSession = null;
  document.getElementById("mainApp").style.display = "none";
  document.getElementById("authScreen").style.display = "flex";
  document.getElementById("loginUsername").value = "";
  document.getElementById("loginPassword").value = "";
  hideMessages();
  switchTab("login");
}

function renderBadge(){
  const badge = document.getElementById("userBadge");
  if(currentSession.isAdmin){
    badge.innerHTML = `<span class="ub-dot" style="background:var(--admin-color)"></span><span style="color:var(--admin-color)">👑 المدير — ${currentSession.username}</span>`;
    badge.style.background = "rgba(245,158,11,0.12)";
    badge.style.border = "1px solid rgba(245,158,11,0.33)";
  } else {
    const r = ROLES[currentSession.role];
    badge.innerHTML = `<span class="ub-dot" style="background:${r.color}"></span><span style="color:${r.color}">${r.icon} ${currentSession.username} — ${r.name}</span>`;
    badge.style.background = r.color + "12";
    badge.style.border = "1px solid " + r.color + "33";
  }
}

// ================ USER BOARD ================
function canEdit(t){ return t.owner === currentSession.role || t.owner === "all" }
function getTaskById(id){ return Object.values(DAYS).flatMap(d => d.tasks).find(t => t.id === id) }
function getStatus(id){ return taskStatuses[id] || "todo" }

function cycleStatus(id){
  const t = getTaskById(id);
  if(!t || !canEdit(t)) return;
  const c = getStatus(id);
  taskStatuses[id] = c === "todo" ? "doing" : c === "doing" ? "done" : "todo";
  saveTasks(currentSession.role, taskStatuses);
  renderUser();
}

function setDay(d){ activeDay = d; renderUser() }
function setFilter(f){ activeFilter = f; renderUser() }

function resetAll(){
  if(confirm("هل أنت متأكد؟ سيتم إعادة جميع مهامك لوضعها الأصلي")){
    taskStatuses = {};
    saveTasks(currentSession.role, taskStatuses);
    renderUser();
  }
}

function renderUser(){
  const day = DAYS[activeDay];
  const all = Object.values(DAYS).flatMap(d => d.tasks);
  const aD = all.filter(t => getStatus(t.id) === "done").length;
  const wP = Math.round((aD / all.length) * 100);

  const wF = document.getElementById("weekFill");
  wF.style.width = wP + "%";
  wF.style.background = wP === 100
    ? "linear-gradient(90deg,#4ade80,#34d399)"
    : "linear-gradient(90deg,var(--brand-primary),var(--brand-gold))";
  document.getElementById("weekPct").textContent = wP + "%";
  document.getElementById("weekPct").style.color = wP === 100 ? "#4ade80" : "var(--brand-primary)";
  document.getElementById("weekCount").textContent = aD + "/" + all.length + " مهمة";

  // Tabs
  let tabs = "";
  Object.entries(DAYS).forEach(([k, d]) => {
    const a = activeDay === k;
    const dd = d.tasks.filter(t => getStatus(t.id) === "done").length;
    tabs += `<button class="day-tab ${a?'active':''}" onclick="setDay('${k}')">
      <div class="dt-name">${d.label}</div><div class="dt-theme">${d.theme}</div>
      <div class="dt-icon">${d.themeIcon}</div>
      ${dd > 0 ? `<div class="dt-prog">${dd}/${d.tasks.length}</div>` : ''}
    </button>`;
  });
  document.getElementById("dayTabs").innerHTML = tabs;

  // Banner
  const total = day.tasks.length;
  const done = day.tasks.filter(t => getStatus(t.id) === "done").length;
  const pct = Math.round((done / total) * 100);
  document.getElementById("themeBanner").innerHTML = `
    <div class="tb-right"><span class="tb-icon">${day.themeIcon}</span><div>
      <div class="tb-title">${day.label} — ${day.theme}</div>
      <div class="tb-count">${total} مهام • ${done} مكتملة</div>
    </div></div>
    <div class="tb-left">
      <div class="tb-track"><div class="tb-fill" style="width:${pct}%;background:${pct===100?'linear-gradient(90deg,#4ade80,#34d399)':'linear-gradient(90deg,var(--brand-primary),var(--brand-gold))'}"></div></div>
      <span class="tb-pct" style="color:${pct===100?'#4ade80':'var(--brand-primary)'}">${pct}%</span>
    </div>`;

  // Filters
  let fH = `<button class="filter-btn" style="background:${activeFilter==='all'?'rgba(200,164,92,0.15)':'rgba(255,255,255,0.04)'};color:${activeFilter==='all'?'var(--brand-primary)':'var(--text-muted)'};border-color:${activeFilter==='all'?'rgba(200,164,92,0.3)':'rgba(255,255,255,0.06)'}" onclick="setFilter('all')">👥 الكل</button>`;
  Object.entries(ROLES).forEach(([k, m]) => {
    fH += `<button class="filter-btn" style="background:${activeFilter===k?m.color+'22':'rgba(255,255,255,0.04)'};color:${activeFilter===k?m.color:'var(--text-muted)'};border-color:${activeFilter===k?m.color+'44':'rgba(255,255,255,0.06)'}" onclick="setFilter('${k}')">${m.icon} ${m.name}</button>`;
  });
  document.getElementById("filters").innerHTML = fH;

  // Kanban
  const filtered = day.tasks.filter(t => activeFilter === "all" || t.owner === activeFilter || t.owner === "all");
  let kH = "";
  STATUSES.forEach(col => {
    const tasks = filtered.filter(t => getStatus(t.id) === col.key);
    let cards = "";
    if(!tasks.length){ cards = `<div class="empty-state">لا توجد مهام</div>` }
    else tasks.forEach(t => {
      const s = getStatus(t.id);
      const m = t.owner === "all" ? null : ROLES[t.owner];
      const mine = canEdit(t);
      const lbl = t.owner === "all"
        ? `<span class="tc-label" style="background:rgba(200,164,92,0.1);color:var(--brand-primary)">👥 اجتماع مشترك</span>`
        : `<span class="tc-label" style="background:${m.color}15;color:${m.color}">${m.icon} ${m.name}</span>`;
      const lockIcon = mine ? '' : `<span class="tc-lock">🔒</span>`;
      cards += `<div class="task-card status-${s} ${mine?'':'locked'}" style="background:${s==='done'?'rgba(74,222,128,0.04)':'rgba(255,255,255,0.03)'};border-color:${s==='done'?'rgba(74,222,128,0.1)':'rgba(255,255,255,0.04)'}" ${mine?`onclick="cycleStatus(${t.id})"`:''}>
        <div class="tc-text">${t.text}</div>
        <div class="tc-footer">${lbl}${lockIcon}</div>
      </div>`;
    });
    kH += `<div class="kanban-col"><div class="col-head">
      <div class="ch-left"><span class="ch-icon">${col.icon}</span><span class="ch-name">${col.label}</span></div>
      <span class="ch-badge" style="background:${col.color}18;color:${col.color}">${tasks.length}</span>
    </div>${cards}</div>`;
  });
  document.getElementById("kanban").innerHTML = kH;
}

// ================ ADMIN DASHBOARD ================
function renderAdmin(){
  const users = loadUsers();

  // Summary stats
  let totalDone = 0, totalPending = 0, totalAll = 0, activeUsers = 0;
  Object.entries(ROLES).forEach(([role, info]) => {
    const taskData = loadTasks(role);
    const roleTasks = Object.values(DAYS).flatMap(d => d.tasks).filter(t => t.owner === role || t.owner === "all");
    const done = roleTasks.filter(t => (taskData[t.id] || "todo") === "done").length;
    totalDone += done;
    totalPending += (roleTasks.length - done);
    totalAll += roleTasks.length;
    const registered = Object.values(users).find(u => u.role === role);
    if(registered) activeUsers++;
  });
  const overallPct = totalAll > 0 ? Math.round((totalDone / totalAll) * 100) : 0;

  document.getElementById("summaryGrid").innerHTML = `
    <div class="summary-item">
      <div class="si-num" style="color:var(--brand-primary)">${activeUsers}/3</div>
      <div class="si-label">مستخدمون مسجّلون</div>
    </div>
    <div class="summary-item">
      <div class="si-num" style="color:#4ade80">${totalDone}</div>
      <div class="si-label">مهام مكتملة</div>
    </div>
    <div class="summary-item">
      <div class="si-num" style="color:#fbbf24">${totalPending}</div>
      <div class="si-label">مهام متبقية</div>
    </div>
    <div class="summary-item">
      <div class="si-num" style="color:var(--content-color)">${overallPct}%</div>
      <div class="si-label">التقدم الإجمالي</div>
    </div>`;

  // Per-user cards
  let grid = "";
  Object.entries(ROLES).forEach(([role, info]) => {
    const taskData = loadTasks(role);
    const registered = Object.entries(users).find(([un, u]) => u.role === role);
    const username = registered ? registered[0] : null;

    const roleTasks = Object.values(DAYS).flatMap(d => d.tasks).filter(t => t.owner === role || t.owner === "all");
    const done = roleTasks.filter(t => (taskData[t.id] || "todo") === "done").length;
    const doing = roleTasks.filter(t => (taskData[t.id] || "todo") === "doing").length;
    const todo = roleTasks.length - done - doing;
    const pct = roleTasks.length > 0 ? Math.round((done / roleTasks.length) * 100) : 0;

    // Per-day breakdown
    let daysHTML = "";
    Object.entries(DAYS).forEach(([k, d]) => {
      const myTasks = d.tasks.filter(t => t.owner === role || t.owner === "all");
      const myDone = myTasks.filter(t => (taskData[t.id] || "todo") === "done").length;
      const dPct = myTasks.length > 0 ? Math.round((myDone / myTasks.length) * 100) : 0;
      const color = dPct === 100 ? "#4ade80" : dPct > 0 ? info.color : "var(--text-muted)";
      daysHTML += `<div class="auc-day">
        <div class="auc-day-name">${d.label.slice(0,3)}</div>
        <div class="auc-day-prog" style="color:${color}">${myDone}/${myTasks.length}</div>
      </div>`;
    });

    grid += `<div class="admin-user-card" style="border-color:${info.color}44">
      <div class="auc-head">
        <div class="auc-user">
          <div class="auc-avatar" style="background:${info.color}22;color:${info.color}">${info.icon}</div>
          <div>
            <div class="auc-name" style="color:${info.color}">${username || "لم يسجّل بعد"}</div>
            <div class="auc-role">${info.title}</div>
          </div>
        </div>
        <span class="auc-status ${username?'active':'inactive'}">${username?'● نشط':'غير مسجّل'}</span>
      </div>
      <div class="auc-progress">
        <div class="auc-prog-label">
          <span>نسبة الإنجاز الأسبوعية</span>
          <span class="auc-prog-pct" style="color:${pct===100?'#4ade80':info.color}">${pct}%</span>
        </div>
        <div class="auc-prog-track">
          <div class="auc-prog-fill" style="width:${pct}%;background:${pct===100?'linear-gradient(90deg,#4ade80,#34d399)':'linear-gradient(90deg,'+info.color+','+info.color+'aa)'}"></div>
        </div>
      </div>
      <div class="auc-stats">
        <div class="auc-stat">
          <div class="auc-stat-num" style="color:#4ade80">${done}</div>
          <div class="auc-stat-label">مكتمل</div>
        </div>
        <div class="auc-stat">
          <div class="auc-stat-num" style="color:#fbbf24">${doing}</div>
          <div class="auc-stat-label">قيد التنفيذ</div>
        </div>
        <div class="auc-stat">
          <div class="auc-stat-num" style="color:#f87171">${todo}</div>
          <div class="auc-stat-label">متبقي</div>
        </div>
      </div>
      <div class="auc-days">${daysHTML}</div>
    </div>`;
  });
  document.getElementById("adminGrid").innerHTML = grid;
}

// ================ AUTO-LOGIN ================
(function init(){
  const s = loadSession();
  if(s){ currentSession = s; enterApp(); return; }

  // Enter key submits
  document.getElementById("loginPassword").addEventListener("keypress", e => {
    if(e.key === "Enter") handleLogin();
  });
  document.getElementById("signupPassword").addEventListener("keypress", e => {
    if(e.key === "Enter") handleSignup();
  });
})();

// Auto-refresh admin view every 5 seconds
setInterval(() => {
  if(currentSession && currentSession.isAdmin){
    renderAdmin();
  }
}, 5000);
</script>
</body>
</html>
