<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>مجالي — لوحة إدارة المتجر</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --brand-primary: #c8a45c;
    --brand-gold: #d4af6e;
    --brand-deeper: #12121f;
    --brand-surface: #1e1e34;
    --brand-surface2: #252542;
    --brand-border: rgba(200,164,92,0.12);
    --text-primary: #f0ece4;
    --text-secondary: #9a9ab0;
    --text-muted: #6b6b82;
    --store-color: #4a9eff;
    --content-color: #c084fc;
    --marketing-color: #34d399;
    --admin-color: #f59e0b;
    --error-color: #f87171;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    font-family:'Cairo',sans-serif; background:var(--brand-deeper);
    color:var(--text-primary); min-height:100vh; direction:rtl; overflow-x:hidden;
  }
  body::before {
    content:''; position:fixed; inset:0;
    background: radial-gradient(ellipse at 20% 0%,rgba(200,164,92,0.04)0%,transparent 60%),
                radial-gradient(ellipse at 80% 100%,rgba(200,164,92,0.03)0%,transparent 60%);
    pointer-events:none;
  }
  .app { position:relative; z-index:1; max-width:1300px; margin:0 auto; padding:20px 16px; }

  /* =============== AUTH SCREEN =============== */
  .auth-screen {
    position:fixed; inset:0; background:var(--brand-deeper);
    display:flex; align-items:center; justify-content:center; z-index:1000;
    padding:20px;
  }
  .auth-screen::before {
    content:''; position:absolute; inset:0;
    background:radial-gradient(ellipse at 50% 30%,rgba(200,164,92,0.06)0%,transparent 60%);
    pointer-events:none;
  }
  .auth-box {
    position:relative; z-index:1; max-width:440px; width:100%;
    background:var(--brand-surface); border:1px solid var(--brand-border);
    border-radius:20px; padding:36px 32px;
    box-shadow:0 20px 60px rgba(0,0,0,0.4);
  }
  .auth-logo {
    text-align:center; margin-bottom:24px;
  }
  .auth-logo img { height:80px; }

  .auth-title {
    text-align:center; font-size:24px; font-weight:900;
    color:var(--text-primary); margin-bottom:6px;
  }
  .auth-subtitle {
    text-align:center; font-size:15px; color:var(--text-secondary);
    margin-bottom:28px; font-weight:500;
  }

  .auth-tabs {
    display:flex; gap:4px; background:rgba(255,255,255,0.03);
    padding:4px; border-radius:12px; margin-bottom:22px;
  }
  .auth-tab {
    flex:1; padding:10px; border:none; background:transparent;
    color:var(--text-muted); font-family:inherit; font-size:15px; font-weight:700;
    cursor:pointer; border-radius:9px; transition:all 0.2s;
  }
  .auth-tab.active {
    background:var(--brand-surface2); color:var(--brand-primary);
    box-shadow:0 2px 8px rgba(0,0,0,0.2);
  }

  .auth-field {
    margin-bottom:16px;
  }
  .auth-field label {
    display:block; font-size:13px; font-weight:700;
    color:var(--text-secondary); margin-bottom:7px;
  }
  .auth-field input, .auth-field select {
    width:100%; padding:12px 14px; font-family:inherit;
    background:var(--brand-surface2); border:1.5px solid rgba(255,255,255,0.06);
    border-radius:10px; color:var(--text-primary); font-size:15px; font-weight:600;
    transition:all 0.2s; text-align:right; direction:rtl;
  }
  .auth-field input:focus, .auth-field select:focus {
    outline:none; border-color:var(--brand-primary);
    background:rgba(200,164,92,0.05);
  }
  .auth-field select { cursor:pointer; }
  .auth-field select option { background:var(--brand-surface); color:var(--text-primary); }

  .auth-submit {
    width:100%; padding:14px; margin-top:10px;
    background:linear-gradient(135deg,var(--brand-primary),var(--brand-gold));
    color:var(--brand-deeper); border:none; border-radius:10px;
    font-family:inherit; font-size:16px; font-weight:800; cursor:pointer;
    transition:all 0.2s;
    box-shadow:0 4px 20px rgba(200,164,92,0.2);
  }
  .auth-submit:hover { transform:translateY(-1px); box-shadow:0 6px 24px rgba(200,164,92,0.3); }
  .auth-submit:active { transform:translateY(0); }

  .auth-error {
    background:rgba(248,113,113,0.1); border:1px solid rgba(248,113,113,0.25);
    color:var(--error-color); padding:10px 14px; border-radius:9px;
    font-size:13px; font-weight:600; margin-bottom:14px; text-align:center;
    display:none;
  }
  .auth-error.show { display:block; }

  .auth-success {
    background:rgba(74,222,128,0.1); border:1px solid rgba(74,222,128,0.25);
    color:#4ade80; padding:10px 14px; border-radius:9px;
    font-size:13px; font-weight:600; margin-bottom:14px; text-align:center;
    display:none;
  }
  .auth-success.show { display:block; }

  .auth-hint {
    text-align:center; font-size:12px; color:var(--text-muted);
    margin-top:18px; font-weight:500;
  }
  .auth-hint code {
    background:rgba(245,158,11,0.12); color:var(--admin-color);
    padding:2px 7px; border-radius:5px; font-family:inherit; font-weight:700;
  }

  /* =============== MAIN HEADER =============== */
  .header {
    display:flex; align-items:center; justify-content:space-between;
    padding:18px 24px; margin-bottom:20px; background:var(--brand-surface);
    border:1px solid var(--brand-border); border-radius:16px;
    position:relative; overflow:hidden; flex-wrap:wrap; gap:12px;
  }
  .header::after {
    content:''; position:absolute; bottom:0; right:0; left:0; height:2px;
    background:linear-gradient(90deg,transparent,var(--brand-primary),transparent);
  }
  .brand { display:flex; align-items:center; gap:14px; }
  .logo-wrap { width:52px; height:52px; display:flex; align-items:center; justify-content:center; }
  .logo-wrap img { width:100%; height:100%; object-fit:contain; }
  .brand-text h1 { font-size:22px; font-weight:900; }
  .brand-text p { font-size:14px; color:var(--text-secondary); font-weight:600; margin-top:2px; }

  .header-actions { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
  .user-badge {
    display:flex; align-items:center; gap:8px;
    padding:8px 16px; border-radius:10px; font-size:14px; font-weight:700;
  }
  .ub-dot { width:10px; height:10px; border-radius:50%; display:inline-block; }
  .hdr-btn {
    padding:8px 16px; border-radius:10px; border:1px solid rgba(255,255,255,0.08);
    background:rgba(255,255,255,0.04); color:var(--text-secondary);
    font-family:inherit; font-size:13px; font-weight:700; cursor:pointer; transition:all 0.2s;
  }
  .hdr-btn:hover { background:rgba(255,255,255,0.08); }
  .hdr-btn.danger:hover { background:rgba(239,68,68,0.1); border-color:rgba(239,68,68,0.3); color:#f87171; }

  /* =============== WEEK BAR =============== */
  .week-bar {
    display:flex; align-items:center; gap:14px; flex-wrap:wrap;
    padding:14px 22px; margin-bottom:16px; background:var(--brand-surface);
    border:1px solid var(--brand-border); border-radius:12px;
  }
  .wb-label { font-size:16px; color:var(--text-secondary); font-weight:700; white-space:nowrap; }
  .wb-track { flex:1; min-width:100px; height:10px; background:rgba(255,255,255,0.06); border-radius:99px; overflow:hidden; }
  .wb-fill { height:100%; border-radius:99px; transition:width 0.5s cubic-bezier(0.4,0,0.2,1); }
  .wb-pct { font-size:20px; font-weight:900; min-width:48px; text-align:left; }
  .wb-count { font-size:14px; color:var(--text-muted); font-weight:600; }

  /* =============== DAY TABS =============== */
  .day-tabs { display:grid; grid-template-columns:repeat(6,1fr); gap:6px; margin-bottom:16px; }
  .day-tab {
    padding:14px 4px; border-radius:12px; border:2px solid transparent;
    background:var(--brand-surface); color:var(--text-muted);
    cursor:pointer; transition:all 0.25s; text-align:center; font-family:inherit;
    position:relative; overflow:hidden;
  }
  .day-tab:hover { background:var(--brand-surface2); color:var(--text-secondary); }
  .day-tab.active {
    border-color:var(--brand-primary);
    background:linear-gradient(135deg,var(--brand-surface2),var(--brand-surface));
    color:var(--text-primary); box-shadow:0 0 20px rgba(200,164,92,0.08);
  }
  .day-tab.active::after { content:''; position:absolute; bottom:0; right:0; left:0; height:2px; background:var(--brand-primary); }
  .dt-name { font-size:16px; font-weight:800; }
  .dt-theme { font-size:12px; margin-top:2px; opacity:0.7; font-weight:600; }
  .dt-icon { font-size:20px; margin-top:4px; }
  .dt-prog { font-size:13px; margin-top:3px; color:#4ade80; font-weight:800; }

  /* =============== THEME BANNER =============== */
  .theme-banner {
    display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px;
    padding:16px 22px; margin-bottom:16px; background:var(--brand-surface);
    border:1px solid var(--brand-border); border-radius:12px;
  }
  .tb-right { display:flex; align-items:center; gap:12px; }
  .tb-icon { font-size:32px; }
  .tb-title { font-size:22px; font-weight:900; }
  .tb-count { font-size:15px; color:var(--text-secondary); font-weight:600; }
  .tb-left { display:flex; align-items:center; gap:10px; }
  .tb-track { width:120px; height:9px; background:rgba(255,255,255,0.08); border-radius:99px; overflow:hidden; }
  .tb-fill { height:100%; border-radius:99px; transition:width 0.4s ease; }
  .tb-pct { font-size:18px; font-weight:900; }

  /* =============== FILTERS =============== */
  .filters { display:flex; gap:6px; margin-bottom:16px; flex-wrap:wrap; }
  .filter-btn {
    padding:9px 20px; border-radius:99px; border:2px solid rgba(255,255,255,0.06);
    font-size:15px; font-weight:700; cursor:pointer; font-family:inherit; transition:all 0.2s;
  }
  .filter-btn:hover { transform:translateY(-1px); }

  /* =============== KANBAN =============== */
  .kanban { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; }
  .kanban-col {
    background:var(--brand-surface); border:1px solid var(--brand-border);
    border-radius:14px; padding:14px; min-height:200px;
    animation:fadeUp 0.4s ease backwards;
  }
  .kanban-col:nth-child(1){animation-delay:.05s}
  .kanban-col:nth-child(2){animation-delay:.1s}
  .kanban-col:nth-child(3){animation-delay:.15s}
  .col-head {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:12px; padding-bottom:10px; border-bottom:1px solid rgba(255,255,255,0.05);
  }
  .ch-left { display:flex; align-items:center; gap:8px; }
  .ch-icon { font-size:18px; }
  .ch-name { font-weight:800; font-size:17px; }
  .ch-badge { padding:3px 11px; border-radius:99px; font-size:14px; font-weight:800; }

  .task-card {
    border-radius:10px; padding:12px 14px; margin-bottom:8px;
    cursor:pointer; transition:all 0.2s; border:1px solid rgba(255,255,255,0.04);
  }
  .task-card:hover { transform:translateY(-1px); box-shadow:0 4px 16px rgba(0,0,0,0.25); }
  .task-card.locked { cursor:default; opacity:0.4; }
  .task-card.locked:hover { transform:none; box-shadow:none; }
  .task-card.locked .tc-text { color:var(--text-muted); }
  .task-card.status-done { opacity:0.5; }
  .task-card.status-done .tc-text { text-decoration:line-through; color:var(--text-muted); }
  .tc-text { font-size:15px; line-height:1.9; margin-bottom:8px; font-weight:600; }
  .tc-footer { display:flex; align-items:center; justify-content:space-between; gap:6px; }
  .tc-label {
    display:inline-flex; align-items:center; gap:4px;
    font-size:13px; padding:3px 10px; border-radius:99px; font-weight:700;
  }
  .tc-lock { font-size:13px; opacity:0.5; }
  .empty-state { text-align:center; color:var(--text-muted); font-size:15px; padding:24px 0; font-weight:600; }

  /* =============== KPIs =============== */
  .kpis {
    margin-top:18px; padding:18px 22px; background:var(--brand-surface);
    border:1px solid var(--brand-border); border-radius:14px;
  }
  .kpis h3 { font-size:19px; font-weight:900; margin-bottom:14px; }
  .kpis-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; }
  .kpi-card { border-radius:12px; padding:14px; }
  .kpi-title { font-weight:900; font-size:15px; margin-bottom:10px; display:flex; align-items:center; gap:6px; }
  .kpi-item { font-size:14px; color:var(--text-secondary); padding:4px 0; font-weight:600; }
  .kpi-item+.kpi-item { border-top:1px solid rgba(255,255,255,0.03); }

  /* =============== ADMIN DASHBOARD =============== */
  .admin-grid {
    display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:18px;
  }
  .admin-user-card {
    background:var(--brand-surface); border:1.5px solid var(--brand-border);
    border-radius:16px; padding:20px; transition:all 0.3s;
  }
  .auc-head {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:14px;
  }
  .auc-user { display:flex; align-items:center; gap:10px; }
  .auc-avatar {
    width:44px; height:44px; border-radius:12px;
    display:flex; align-items:center; justify-content:center; font-size:22px;
  }
  .auc-name { font-size:16px; font-weight:900; }
  .auc-role { font-size:12px; color:var(--text-secondary); font-weight:600; }
  .auc-status {
    padding:4px 10px; border-radius:99px; font-size:11px; font-weight:700;
  }
  .auc-status.active { background:rgba(74,222,128,0.12); color:#4ade80; }
  .auc-status.inactive { background:rgba(248,113,113,0.12); color:#f87171; }

  .auc-progress { margin-bottom:14px; }
  .auc-prog-label {
    display:flex; justify-content:space-between; align-items:center;
    font-size:13px; font-weight:700; color:var(--text-secondary);
    margin-bottom:6px;
  }
  .auc-prog-pct { font-size:18px; font-weight:900; }
  .auc-prog-track { height:10px; background:rgba(255,255,255,0.06); border-radius:99px; overflow:hidden; }
  .auc-prog-fill { height:100%; border-radius:99px; transition:width 0.5s; }

  .auc-stats {
    display:grid; grid-template-columns:repeat(3,1fr); gap:8px;
    margin-bottom:14px;
  }
  .auc-stat {
    background:rgba(255,255,255,0.03); border-radius:10px; padding:10px 8px;
    text-align:center;
  }
  .auc-stat-num { font-size:20px; font-weight:900; }
  .auc-stat-label { font-size:11px; color:var(--text-muted); font-weight:700; margin-top:2px; }

  .auc-days { display:grid; grid-template-columns:repeat(6,1fr); gap:3px; }
  .auc-day {
    padding:6px 2px; text-align:center; border-radius:6px;
    background:rgba(255,255,255,0.03); font-size:10px;
    display:flex; flex-direction:column; gap:2px;
  }
  .auc-day-name { font-weight:700; color:var(--text-secondary); }
  .auc-day-prog { font-weight:800; }

  .admin-summary {
    background:var(--brand-surface); border:1px solid var(--brand-border);
    border-radius:14px; padding:18px 22px; margin-bottom:18px;
  }
  .admin-summary h3 { font-size:18px; font-weight:900; margin-bottom:14px; }
  .summary-grid {
    display:grid; grid-template-columns:repeat(4,1fr); gap:10px;
  }
  .summary-item {
    background:rgba(255,255,255,0.03); border-radius:12px; padding:14px;
    text-align:center;
  }
  .si-num { font-size:28px; font-weight:900; }
  .si-label { font-size:12px; color:var(--text-secondary); font-weight:700; margin-top:4px; }

  .footer {
    margin-top:18px; text-align:center; font-size:14px; color:var(--text-muted);
    padding:14px; font-weight:600;
  }
  .footer .brand-mark { color:var(--brand-primary); font-weight:900; }

  @keyframes fadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

  @media(max-width:768px){
    .header{flex-direction:column;text-align:center}
    .brand{justify-content:center}
    .kanban{grid-template-columns:1fr}
    .kpis-grid{grid-template-columns:1fr}
    .day-tabs{grid-template-columns:repeat(3,1fr)}
    .admin-grid{grid-template-columns:1fr}
    .summary-grid{grid-template-columns:repeat(2,1fr)}
    .brand-text h1{font-size:18px}
    .auth-box{padding:28px 22px}
  }
</style>
</head>
<body>

<!-- =============== AUTH SCREEN =============== -->
<div class="auth-screen" id="authScreen">
  <div class="auth-box">
    <div class="auth-logo">
      <img src="https://cdn.salla.sa/form-builder/Re5iPZztkH16QkdqJ8PVY9lVfpoIbwAM10ewhNDL.png" alt="مجالي">
    </div>
    <div class="auth-title" id="authTitle">تسجيل الدخول</div>
    <div class="auth-subtitle" id="authSubtitle">أهلاً بعودتك — ادخل بياناتك للمتابعة</div>

    <div class="auth-tabs">
      <button class="auth-tab active" id="tabLogin" onclick="switchTab('login')">تسجيل الدخول</button>
      <button class="auth-tab" id="tabSignup" onclick="switchTab('signup')">إنشاء حساب</button>
    </div>

    <div class="auth-error" id="authError"></div>
    <div class="auth-success" id="authSuccess"></div>

    <!-- Login form -->
    <div id="loginForm">
      <div class="auth-field">
        <label for="loginUsername">اسم المستخدم</label>
        <input type="text" id="loginUsername" placeholder="ادخل اسم المستخدم" autocomplete="username">
      </div>
      <div class="auth-field">
        <label for="loginPassword">كلمة المرور</label>
        <input type="password" id="loginPassword" placeholder="ادخل كلمة المرور" autocomplete="current-password">
      </div>
      <button class="auth-submit" onclick="handleLogin()">دخول</button>
    </div>

    <!-- Signup form -->
    <div id="signupForm" style="display:none">
      <div class="auth-field">
        <label for="signupRole">اختر دورك</label>
        <select id="signupRole">
          <option value="">-- اختر الدور --</option>
          <option value="store">🏪 مدير المتجر والمنتجات</option>
          <option value="content">🎨 مسؤول المحتوى والتصميم</option>
          <option value="marketing">📢 مسؤول التسويق والعملاء</option>
        </select>
      </div>
      <div class="auth-field">
        <label for="signupUsername">اسم المستخدم</label>
        <input type="text" id="signupUsername" placeholder="اختر اسم مستخدم" autocomplete="username">
      </div>
      <div class="auth-field">
        <label for="signupPassword">كلمة المرور</label>
        <input type="password" id="signupPassword" placeholder="اختر كلمة مرور (6 أحرف على الأقل)" autocomplete="new-password">
      </div>
      <button class="auth-submit" onclick="handleSignup()">إنشاء الحساب</button>
      <div class="auth-hint">كل دور يقدر يسجّل به مستخدم واحد فقط</div>
    </div>
  </div>
</div>

<!-- =============== MAIN APP =============== -->
<div class="app" id="mainApp" style="display:none">
  <div class="header">
    <div class="brand">
      <div class="logo-wrap">
        <img src="https://cdn.salla.sa/form-builder/Re5iPZztkH16QkdqJ8PVY9lVfpoIbwAM10ewhNDL.png" alt="مجالي">
      </div>
      <div class="brand-text">
        <h1>لوحة إدارة المتجر</h1>
        <p id="headerSubtitle">السبت → الخميس • إدارة يومية للفريق</p>
      </div>
    </div>
    <div class="header-actions">
      <div class="user-badge" id="userBadge"></div>
      <button class="hdr-btn" onclick="logout()">🚪 تسجيل الخروج</button>
      <button class="hdr-btn danger" id="resetBtn" onclick="resetAll()" style="display:none">🗑️ تصفير</button>
    </div>
  </div>

  <!-- Regular user view -->
  <div id="userView">
    <div class="week-bar">
      <span class="wb-label">📊 تقدم الأسبوع</span>
      <div class="wb-track"><div class="wb-fill" id="weekFill"></div></div>
      <span class="wb-pct" id="weekPct">0%</span>
      <span class="wb-count" id="weekCount"></span>
    </div>

    <div class="day-tabs" id="dayTabs"></div>
    <div class="theme-banner" id="themeBanner"></div>
    <div class="filters" id="filters"></div>
    <div class="kanban" id="kanban"></div>

    <div class="kpis">
      <h3>🎯 الأهداف الأسبوعية (6 أيام)</h3>
      <div class="kpis-grid">
        <div class="kpi-card" style="background:rgba(74,158,255,0.06);border:1px solid rgba(74,158,255,0.12)">
          <div class="kpi-title" style="color:var(--store-color)">🏪 مدير المتجر</div>
          <div class="kpi-item">◾ 18-25 منتج جديد</div>
          <div class="kpi-item">◾ تحسين 10 صفحات منتجات</div>
          <div class="kpi-item">◾ مراجعة أسعار المنافسين</div>
          <div class="kpi-item">◾ تحديث وترتيب التصنيفات</div>
        </div>
        <div class="kpi-card" style="background:rgba(192,132,252,0.06);border:1px solid rgba(192,132,252,0.12)">
